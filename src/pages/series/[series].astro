---
import type { GetStaticPaths } from 'astro';
import SeriesLayout from '../../layouts/SeriesLayout.astro';
import { getAllSeries, getSeriesPosts } from '../../utils/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const allSeries = await getAllSeries();

  return Promise.all(
    allSeries.map(async (series) => {
      const posts = await getSeriesPosts(series);

      // Format series name for display
      const seriesTitle = series
        .split('-')
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ');

      return {
        params: { series },
        props: {
          title: seriesTitle,
          description: `All posts in the ${seriesTitle} series`,
          posts,
        },
      };
    })
  );
};

const { title, description, posts } = Astro.props;
---

<SeriesLayout title={title} description={description} posts={posts} />

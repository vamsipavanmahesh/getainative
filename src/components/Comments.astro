---
// Giscus comments integration
// Set up at: https://giscus.app/
// Fill in the data attributes after configuring Giscus for your repo

interface Props {
  repo?: string;
  repoId?: string;
  category?: string;
  categoryId?: string;
}

const {
  repo = '',
  repoId = '',
  category = 'Comments',
  categoryId = ''
} = Astro.props;

const isConfigured = repo && repoId && categoryId;
---

{isConfigured ? (
  <section class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
    <h2 class="text-xl font-semibold mb-6">Comments</h2>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo={repo}
      data-repo-id={repoId}
      data-category={category}
      data-category-id={categoryId}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </section>
) : (
  <section class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
    <h2 class="text-xl font-semibold mb-6">Comments</h2>
    <p class="text-sm" style="color: var(--color-text-muted);">
      Comments are not configured yet. Set up Giscus to enable discussions.
    </p>
  </section>
)}

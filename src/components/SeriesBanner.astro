---
import type { CollectionEntry } from 'astro:content';

interface Props {
  series: string;
  posts: CollectionEntry<'posts'>[];
  currentSlug: string;
  currentOrder?: number;
}

const { series, posts, currentSlug, currentOrder } = Astro.props;

// Sort posts by seriesOrder
const sortedPosts = [...posts].sort(
  (a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)
);

const currentIndex = sortedPosts.findIndex((p) => p.slug === currentSlug);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

// Format series name for display
const seriesTitle = series
  .split('-')
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');
---

<aside class="mb-10 p-4 rounded-lg" style="background-color: var(--color-border);">
  <div class="flex items-center justify-between mb-3">
    <a
      href={`/series/${series}`}
      class="text-sm font-medium hover:opacity-80 transition-opacity"
      style="color: var(--color-accent);"
    >
      {seriesTitle}
    </a>
    <span class="text-sm" style="color: var(--color-text-muted);">
      Part {currentOrder ?? currentIndex + 1} of {posts.length}
    </span>
  </div>

  <div class="flex justify-between text-sm">
    {prevPost ? (
      <a
        href={`/${series}/${prevPost.slug.split('/').pop()}`}
        class="hover:opacity-80 transition-opacity"
        style="color: var(--color-text-muted);"
        aria-label={`Previous post: ${prevPost.data.title}`}
      >
        ← Previous
      </a>
    ) : (
      <span></span>
    )}
    {nextPost ? (
      <a
        href={`/${series}/${nextPost.slug.split('/').pop()}`}
        class="hover:opacity-80 transition-opacity"
        style="color: var(--color-text-muted);"
        aria-label={`Next post: ${nextPost.data.title}`}
      >
        Next →
      </a>
    ) : (
      <span></span>
    )}
  </div>
</aside>
